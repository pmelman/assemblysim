# Silicon Citizens' Assembly - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API Keys (at least one required for persona generation)
# =============================================================================

# OpenRouter (recommended - provides access to multiple models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Direct provider keys (optional, if not using OpenRouter)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity (for research/briefing books in Phase 2+)
PERPLEXITY_API_KEY=pplx-...

# =============================================================================
# LLM Configuration
# =============================================================================

# Provider: "openrouter", "openai", or "anthropic"
LLM_PROVIDER=openrouter

# Model IDs (OpenRouter format: provider/model-name)
# See available models: https://openrouter.ai/models
WRITER_MODEL=anthropic/claude-3.5-sonnet
CITIZEN_MODEL=anthropic/claude-3.5-sonnet
UTILITY_MODEL=openai/gpt-4o-mini

# Generation parameters
TEMPERATURE=0.7
MAX_TOKENS=500
WRITER_MAX_TOKENS=1000

# =============================================================================
# Assembly Parameters
# =============================================================================

DEFAULT_NUM_CITIZENS=40
DEFAULT_NUM_GROUPS=5
DEFAULT_NUM_ROUNDS=3

# =============================================================================
# Database (for Phase 2+)
# =============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/sca

# =============================================================================
# Application Settings
# =============================================================================

DEBUG=True
CORS_ORIGINS=["http://localhost:3000"]
